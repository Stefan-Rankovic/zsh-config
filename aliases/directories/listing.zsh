alias ls="eza -1 --icons=auto" # [L]i[S]t
alias la="ls -a --sort=name --group-directories-first" # [L]ist [A]ll

alias lm="ls -lh" # [L]ist with [M]etadata
alias lam="la -lh" # [L]ist [A]ll with [M]etadata

alias lt="ls --tree" # [L]ist as [T]ree
alias ltd1="lt --level 1" # [L]ist as [T]ree with [D]epth [1]
alias ltd2="lt --level 2" # [L]ist as [T]ree with [D]epth [2]
alias ltd3="lt --level 3" # [L]ist as [T]ree with [D]epth [3]
